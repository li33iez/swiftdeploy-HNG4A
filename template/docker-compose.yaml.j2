services:
  api:
    image: {{ services.image }}
    container_name: swiftdeploy-api
    restart: {{ services.restart_policy }}
    user: "appuser"
    cap_drop:
      - ALL
    environment:
      MODE: "{{ services.mode }}"
      APP_VERSION: "{{ services.version }}"
      APP_PORT: "{{ services.port }}"
    volumes:
      - {{ volumes.logs }}:/app/logs
    networks:
      - {{ network.name }}
    healthcheck:
      test: ["CMD", "python", "-c", "import urllib.request; urllib.request.urlopen('http://localhost:{{ services.port }}/healthz')"]
      interval: 15s
      timeout: 5s
      retries: 3
      start_period: 10s
    expose:
      - "{{ services.port }}"

  nginx:
    image: {{ nginx.image }}
    container_name: swiftdeploy-nginx
    restart: {{ services.restart_policy }}
    ports:
      - "{{ nginx.port }}:{{ nginx.port }}"
    volumes:
      - ./nginx.conf:/etc/nginx/conf.d/default.conf:ro
      - {{ volumes.logs }}:/var/log/nginx
    networks:
      - {{ network.name }}
    depends_on:
      api:
        condition: service_healthy

networks:
  {{ network.name }}:
    driver: {{ network.driver_type }}

volumes:
  {{ volumes.logs }}:
    driver: local
